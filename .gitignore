# Python
backend/venv/
backend/__pycache__/
backend/*.pyc
backend/*.egg-info/

# Node
frontend/node_modules/
frontend/build/

# Env files
**/.env
**/.env.*
!**/.env.example
!**/.env.sample

# Runtime logs / temp output
backend/.tmp/
frontend/*.log

# Mac
.DS_Store

# Ollama / model files
*.gguf
*.bin

# Key / cert artifacts (avoid accidental commits)
**/*.pem
**/*.key
**/*.crt
**/*.cer
**/*.p12
**/*.pfx
**/*.jks
**/*.keystore
**/.ssh/
**/id_rsa
**/id_rsa.pub
**/id_ed25519
**/id_ed25519.pub
